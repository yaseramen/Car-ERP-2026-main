# قاعدة البيانات (Turso) - مطلوب
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# الجلسات والأمان - مطلوب
AUTH_SECRET=your-secret-key-use-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# النطاق المخصص (للإنتاج على Vercel)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# صورة البانر الترويجي (اختياري) — أو ضع الملف public/marketing/efct-promo-hero.webp من GitHub
# NEXT_PUBLIC_MARKETING_HERO_URL=https://xxxx.public.blob.vercel-storage.com/efct-promo-hero.webp

# انتهاء إعلانات السوق (Vercel Cron) — نفس القيمة في Vercel → Cron → Authorization Header
# CRON_SECRET=openssl-rand-hex-32

# صور إعلانات السوق ورفع شعار الشركة وملاحظات المطور (Vercel Blob) — Vercel → Storage → Read/Write Token
# بدونها: السوق/الشعار بالرفع من الجهاز يعطي خطأ؛ يمكن وضع رابط https مباشر لصورة الشعار في إعدادات الشركة
# BLOB_READ_WRITE_TOKEN=

# OBD - اختياري (للتشخيص الذكي)
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
